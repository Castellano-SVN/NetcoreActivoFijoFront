# Plantilla de referencia. Copiar a .env.local para overrides personales (no se commitea).
#
# Next.js carga archivos según el comando:
#   npm run dev          → .env.development (+ .env.local si existe)
#   npm run dev:qa       → .env.qa (+ .env.local si existe)
#   npm run build        → .env.production
#   npm run build:qa     → .env.qa
#   npm run start        → usa variables embebidas en el build previo
#
# Las variables NEXT_PUBLIC_* se incluyen en el bundle del cliente al compilar.
# Tras cambiarlas, reinicia dev o vuelve a ejecutar build.

NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:9000/api/
NEXT_ENVIROMENT=development
